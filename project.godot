; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Backrooms Roguelite"
config/description="横版后室探索射击 Roguelite"
config/version="0.1.0"
run/main_scene="res://scenes/ui/main_menu.tscn"
config/features=PackedStringArray("4.7")
config/icon="res://icon.svg"

[autoload]

GameManager="*res://scripts/systems/game_manager.gd"
RunManager="*res://scripts/systems/run_manager.gd"
MetaProgression="*res://scripts/systems/meta_progression.gd"
AudioManager="*res://scripts/systems/audio_manager.gd"
McpInteractionServer="*res://scripts/systems/mcp_interaction_server.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

